# Frontend (Vite) — copy to `.env.local` for local development.
# Vite only exposes variables prefixed with VITE_.
#
# Leave empty when using `npm run dev` with the default Vite proxy
# (`/api` and `/auth` → http://localhost:8000). Set this when the API
# is on another origin (e.g. staged backend).

VITE_API_BASE_URL=

# Backend (Render / local — not read by Vite)
# AUTOAPPLYER_CORS_ORIGINS=https://your-app.netlify.app
# AUTOAPPLYER_SECURE_COOKIES=true
# AUTOAPPLYER_SESSION_SECRET=
